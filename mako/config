font=Cozette 11
format=<b>%a ⏵</b> %s\n%b
sort=-time
output=DP-3
layer=overlay
anchor=top-right
background-color=#2e3440
width=300
height=110
margin=2
padding=5,5,10
border-size=1
border-color=#3e8fb0
border-radius=10
icons=0
max-icon-size=64
default-timeout=5000
ignore-timeout=1

[urgency=normal]
border-color=#3e8fb0

[urgency=high]
border-color=#f6c117
border-size=3
default-timeout=5000

[summary~="log-.*"]
border-color=#3e8fb0
